{
  "name": "bella-sample-adonisjs",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node ace serve < /dev/null",
    "start": "node bin/server.js",
    "build": "node ace build"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js"
  },
  "dependencies": {
    "@adonisjs/core": "^7.3.1",
    "@bella-baxter/config": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.2.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/node": "~25.5.0",
    "typescript": "~6.0.2"
  }
}
