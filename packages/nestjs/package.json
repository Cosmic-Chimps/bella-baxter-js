{
  "name": "@bella-baxter/nestjs",
  "version": "0.1.0",
  "description": "Bella Baxter NestJS module — registers BellaConfig as an injectable service",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bella-baxter/sdk": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10",
    "@nestjs/core": ">=10"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^25.5.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "keywords": ["bella-baxter", "secrets", "nestjs", "module"],
  "license": "MIT"
}
