{
  "name": "@bella-baxter/config",
  "version": "0.1.0",
  "private": true,
  "description": "Live-reloading secrets provider for Node.js apps — Express, NestJS, Next.js and more",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./express": {
      "import": "./dist/adapters/express.js",
      "types": "./dist/adapters/express.d.ts"
    },
    "./nestjs": {
      "import": "./dist/adapters/nestjs.js",
      "types": "./dist/adapters/nestjs.d.ts"
    },
    "./next": {
      "import": "./dist/adapters/next.js",
      "types": "./dist/adapters/next.d.ts"
    },
    "./fastify": {
      "import": "./dist/adapters/fastify.js",
      "types": "./dist/adapters/fastify.d.ts"
    },
    "./adonis": {
      "import": "./dist/adapters/adonis.js",
      "types": "./dist/adapters/adonis.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bella-baxter/sdk": "workspace:*"
  },
  "peerDependencies": {
    "express": ">=4",
    "@nestjs/common": ">=10",
    "@nestjs/core": ">=10",
    "fastify": ">=4",
    "fastify-plugin": ">=4",
    "@adonisjs/core": ">=6"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "@nestjs/common": { "optional": true },
    "@nestjs/core": { "optional": true },
    "fastify": { "optional": true },
    "fastify-plugin": { "optional": true },
    "@adonisjs/core": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^25.5.0",
    "@types/express": "^5.0.6",
    "fastify": "^5.8.3",
    "fastify-plugin": "^5.1.0"
  },
  "keywords": ["bella-baxter", "secrets", "config", "express", "nestjs", "nextjs"],
  "license": "MIT"
}
