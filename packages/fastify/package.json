{
  "name": "@bella-baxter/fastify",
  "version": "0.1.1-preview.13",
  "description": "Bella Baxter Fastify plugin \u2014 decorates the Fastify instance with live-reloading secrets",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
