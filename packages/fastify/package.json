  },
  "peerDependencies": {
    "fastify": ">=4",
    "fastify-plugin": ">=4"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^25.5.0",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0"
  },
  "keywords": [
    "bella-baxter",
