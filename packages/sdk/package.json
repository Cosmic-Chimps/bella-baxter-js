{
  "name": "@bella-baxter/sdk",
  "version": "0.1.1-preview.68",
  "description": "TypeScript client for the Bella Baxter API \u2014 wraps Kiota-generated client with auth + E2EE",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bella-baxter/kiota-client": "workspace:*",
    "@microsoft/kiota-abstractions": "^1.0.0-0",
    "@microsoft/kiota-http-fetchlibrary": "^1.0.0-0"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "@types/node": "^25.5.0"
  },
  "keywords": [
    "bella-baxter",
    "sdk",
    "secrets",
    "openapi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cosmic-Chimps/bella-baxter.git",
    "directory": "apps/sdk/js/packages/sdk"
  },
  "homepage": "https://github.com/Cosmic-Chimps/bella-baxter/tree/main/apps/sdk/js/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/Cosmic-Chimps/bella-baxter/issues"
  }
}
