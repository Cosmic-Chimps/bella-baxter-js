{
  "name": "@bella-baxter/kiota-client",
  "version": "0.1.1-preview.70",
  "description": "Kiota-generated TypeScript client for the full Bella Baxter API \u2014 used by CLI and JS consumers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@microsoft/kiota-abstractions": "^1.0.0-0",
    "@microsoft/kiota-http-fetchlibrary": "^1.0.0-0",
    "@microsoft/kiota-serialization-json": "^1.0.0-0",
    "@microsoft/kiota-serialization-text": "^1.0.0-0",
    "@microsoft/kiota-serialization-form": "^1.0.0-0",
    "@microsoft/kiota-serialization-multipart": "^1.0.0-0",
    "@microsoft/kiota-authentication-azure": "^1.0.0-0"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "@types/node": "^25.5.0"
  },
  "keywords": [
    "bella-baxter",
    "sdk",
    "kiota",
    "openapi"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cosmic-Chimps/bella-baxter.git",
    "directory": "apps/sdk/js/packages/kiota-client"
  },
  "homepage": "https://github.com/Cosmic-Chimps/bella-baxter/tree/main/apps/sdk/js/packages/kiota-client#readme",
  "bugs": {
    "url": "https://github.com/Cosmic-Chimps/bella-baxter/issues"
  }
}
